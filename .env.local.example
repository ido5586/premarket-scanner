# TradingView session cookies for the authenticated scanner endpoint.
# These expire every few weeks and must be refreshed from browser DevTools:
# Application → Cookies → tradingview.com
TV_SESSION_ID=your_sessionid_here
TV_SESSION_SIGN=your_sessionid_sign_here

# Basic Auth credentials for browser access
BASIC_AUTH_USER=your_basic_auth_user
BASIC_AUTH_PASSWORD=your_basic_auth_password
